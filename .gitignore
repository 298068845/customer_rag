# Local model files are large and should be downloaded per machine.
models/embeddings/**
models/llm/**
!models/embeddings/.gitkeep
!models/llm/.gitkeep

# Runtime data and generated indexes.
data/index/**
data/raw/**
data/browser_profile/**
data/jobs/**
data/talk_rag/**
data/tmp/**
data/*.json
!data/index/.gitkeep
!data/raw/.gitkeep

# Python cache files.
__pycache__/
*.py[cod]
.venv/

# Local runtime logs and temporary WeChat bridge files.
*.log
wechatExtension/send-text.txt
wechatExtension/last-selected.txt
wechatExtension/rag-bridge.log
wechatExtension/rag-bridge-test.log
wechatExtension/preview-test-result.ini
wechatExtension/*-test-result.ini

# Local llama.cpp runtime binaries.
tools/llama.cpp/**
!tools/llama.cpp/
!tools/llama.cpp/*/
!tools/llama.cpp/*/.gitkeep
